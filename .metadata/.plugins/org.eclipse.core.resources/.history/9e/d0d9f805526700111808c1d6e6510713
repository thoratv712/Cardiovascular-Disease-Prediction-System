                     </tr>
                     <tr>
                        <td><strong>🚀 XGBoost</strong></td>
                        <td><%=hml_acc%></td>
                        <td><%=hml_pre%></td>
                        <td><%=hml_rec%></td>
                        <td><%=hml_f1%></td>
                        <td>Good</td>
                     </tr>
                  </table>
               </div>
            </div>
         </div>

         <!-- Action Buttons -->
