   <div><br/><br/></div>
   <div><br/><br/></div>

   <div id="service" class="services wow fadeIn">
      <div class="container">

         <!-- Title -->
         <div class="row">
            <div class="col-md-12 text-center"
                 style="margin-bottom:25px;">
               <h2 style="color:#1565C0;">
                  📊 Model Performance Analysis
               </h2>
               <p style="color:#666;">
                  Comparison of Random Forest,
                  SVM and XGBoost classifiers
               </p>
            </div>
         </div>

         <!-- Metric Cards -->
         <div class="row" style="margin-bottom:20px;">

            <div class="col-md-4">
               <div style="background:#E3F2FD;
                           border-radius:10px;
                           padding:20px;
                           margin-bottom:15px;">
                  <h5 style="color:#1565C0;
                             margin-bottom:12px;">
                     🌲 Random Forest
                  </h5>
                  <table style="width:100%;font-size:14px;">
                     <tr>
                        <td>Accuracy:</td>
                        <td><strong><%=rf_acc%>%</strong></td>
                     </tr>
                     <tr>
                        <td>Precision:</td>
                        <td><strong><%=rf_pre%>%</strong></td>
                     </tr>
                     <tr>
                        <td>Recall:</td>
                        <td><strong><%=rf_rec%>%</strong></td>
                     </tr>
                     <tr>
                        <td>F1-Score:</td>
                        <td><strong><%=rf_f1%>%</strong></td>
                     </tr>
                  </table>
               </div>
            </div>

            <div class="col-md-4">
               <div style="background:#F3E5F5;
                           border-radius:10px;
                           padding:20px;
                           margin-bottom:15px;">
                  <h5 style="color:#6A1B9A;
                             margin-bottom:12px;">
                     ⚙ SVM
                  </h5>
                  <table style="width:100%;font-size:14px;">
                     <tr>
                        <td>Accuracy:</td>
                        <td><strong><%=svm_acc%>%</strong></td>
                     </tr>
                     <tr>
                        <td>Precision:</td>
                        <td><strong><%=svm_pre%>%</strong></td>
                     </tr>
                     <tr>
                        <td>Recall:</td>
                        <td><strong><%=svm_rec%>%</strong></td>
                     </tr>
                     <tr>
                        <td>F1-Score:</td>
                        <td><strong><%=svm_f1%>%</strong></td>
                     </tr>
                  </table>
               </div>
            </div>

            <div class="col-md-4">
               <div style="background:#E8F5E9;
                           border-radius:10px;
                           padding:20px;
                           margin-bottom:15px;">
                  <h5 style="color:#2E7D32;
                             margin-bottom:12px;">
                     🚀 XGBoost
                  </h5>
                  <table style="width:100%;font-size:14px;">
                     <tr>
                        <td>Accuracy:</td>
                        <td><strong><%=hml_acc%>%</strong></td>
                     </tr>
                     <tr>
                        <td>Precision:</td>
                        <td><strong><%=hml_pre%>%</strong></td>
                     </tr>
                     <tr>
                        <td>Recall:</td>
                        <td><strong><%=hml_rec%>%</strong></td>
                     </tr>
                     <tr>
                        <td>F1-Score:</td>
                        <td><strong><%=hml_f1%>%</strong></td>
                     </tr>
                  </table>
               </div>
            </div>

         </div>

         <!-- Accuracy Chart -->
         <div class="row">
            <div class="col-md-12">
               <div class="model-section">
                  <h4>📊 Accuracy Comparison</h4>
                  <div id="accuracyChart"
                       style="width:100%;
                              height:400px;">
                  </div>
               </div>
            </div>
         </div>

         <!-- Combined Chart -->
         <div class="row" style="margin-top:20px;">
            <div class="col-md-12">
               <div class="model-section">
                  <h4>📊 Combined Metrics Comparison</h4>
                  <div id="combinedChart"
                       style="width:100%;
                              height:400px;">
                  </div>
               </div>
            </div>
         </div>

         <!-- Performance Table -->
         <div class="row" style="margin-top:20px;">
            <div class="col-md-12">
               <div class="model-section">
                  <h4>📋 Detailed Performance Table</h4>
                  <table class="perf-table">
                     <tr>
                        <th>Model</th>
                        <th>Accuracy (%)</th>
                        <th>Precision (%)</th>
                        <th>Recall (%)</th>
                        <th>F1-Score (%)</th>
                        <th>Status</th>
                     </tr>
                     <tr>
                        <td>
                           <strong>🌲 Random Forest</strong>
                        </td>
                        <td><%=rf_acc%></td>
                        <td><%=rf_pre%></td>
                        <td><%=rf_rec%></td>
                        <td><%=rf_f1%></td>
                        <td>
                           <span class="best-badge">
                              ✓ Best Model
                           </span>
                        </td>
                     </tr>
                     <tr>
                        <td><strong>⚙ SVM</strong></td>
                        <td><%=svm_acc%></td>
                        <td><%=svm_pre%></td>
                        <td><%=svm_rec%></td>
                        <td><%=svm_f1%></td>
