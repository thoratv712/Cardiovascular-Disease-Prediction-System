<%@ page language="java" contentType="text/html; charset=ISO-8859-1"
    pageEncoding="ISO-8859-1"%>
<%@ page import="java.sql.*" %>
<%@ page import="com.connection.Dbconn" %>
<!DOCTYPE html>
<html lang="en">
<head>
   <meta charset="utf-8">
   <meta http-equiv="X-UA-Compatible" content="IE=edge">
   <meta name="viewport" content="width=device-width, initial-scale=1">
   <title>Life Care - Analysis</title>
   <link rel="shortcut icon"
         href="images/fevicon.ico.png"
         type="image/x-icon"/>
   <link rel="stylesheet" href="css/bootstrap.min.css">
   <link rel="stylesheet" href="style.css">
   <link rel="stylesheet" href="css/colors.css">
   <link rel="stylesheet" href="css/versions.css">
   <link rel="stylesheet" href="css/responsive.css">
   <link rel="stylesheet" href="css/custom.css">

  <script src="jsnew/jquery-1.9.1.min.js"></script>
<script src="jsnew/highcharts.js"></script>

   <style>
      .metric-card {
         background: white;
         border-radius: 10px;
         padding: 20px;
         text-align: center;
         box-shadow: 0 2px 15px rgba(0,0,0,0.1);
         margin: 10px;
      }
      .model-section {
         background: white;
         border-radius: 10px;
         padding: 25px;
         margin: 15px 0;
         box-shadow: 0 2px 15px rgba(0,0,0,0.1);
      }
      .model-section h4 {
         color: #1565C0;
         border-bottom: 2px solid #E3F2FD;
         padding-bottom: 10px;
         margin-bottom: 20px;
      }
      .export-btn {
         display: inline-block;
         padding: 10px 25px;
         background: #2E7D32;
         color: white;
         border-radius: 6px;
         text-decoration: none;
         font-size: 14px;
         font-weight: bold;
         margin: 10px 5px;
      }
      .export-btn:hover {
         background: #1B5E20;
         color: white;
         text-decoration: none;
      }
      .predict-btn-link {
         display: inline-block;
         padding: 10px 25px;
         background: #D32F2F;
         color: white;
         border-radius: 6px;
         text-decoration: none;
         font-size: 14px;
         font-weight: bold;
         margin: 10px 5px;
      }
      .predict-btn-link:hover {
         background: #B71C1C;
         color: white;
         text-decoration: none;
      }
      .perf-table {
         width: 100%;
         border-collapse: collapse;
         margin-top: 15px;
      }
      .perf-table th {
         background: #1565C0;
         color: white;
         padding: 10px 12px;
         text-align: left;
         font-size: 13px;
      }
      .perf-table td {
         padding: 10px 12px;
         border-bottom: 1px solid #eee;
         font-size: 13px;
      }
      .perf-table tr:hover { background: #F5F5F5; }
      .best-badge {
         background: #E8F5E9;
         color: #2E7D32;
         padding: 3px 10px;
         border-radius: 10px;
         font-size: 12px;
         font-weight: bold;
      }
   </style>

<%
   // Load all values first in Java
   Dbconn.configuration_matrix_values_RF();
   Dbconn.configuration_matrix_values_SVM();
   Dbconn.configuration_matrix_values_HML();

   // Helper — if empty use 0
   String rf_acc  = (Dbconn.rf_acc  == null ||
                     Dbconn.rf_acc.isEmpty())
                     ? "0" : Dbconn.rf_acc;
   String rf_pre  = (Dbconn.rf_pre  == null ||
                     Dbconn.rf_pre.isEmpty())
                     ? "0" : Dbconn.rf_pre;
   String rf_rec  = (Dbconn.rf_recall == null ||
                     Dbconn.rf_recall.isEmpty())
                     ? "0" : Dbconn.rf_recall;
   String rf_f1   = (Dbconn.rf_f1_score == null ||
                     Dbconn.rf_f1_score.isEmpty())
                     ? "0" : Dbconn.rf_f1_score;

   String svm_acc = (Dbconn.SVM_acc == null ||
                     Dbconn.SVM_acc.isEmpty())
                     ? "0" : Dbconn.SVM_acc;
   String svm_pre = (Dbconn.SVM_pre == null ||
                     Dbconn.SVM_pre.isEmpty())
                     ? "0" : Dbconn.SVM_pre;
   String svm_rec = (Dbconn.SVM_recall == null ||
                     Dbconn.SVM_recall.isEmpty())
                     ? "0" : Dbconn.SVM_recall;
   String svm_f1  = (Dbconn.SVM_f1_score == null ||
                     Dbconn.SVM_f1_score.isEmpty())
                     ? "0" : Dbconn.SVM_f1_score;

   String hml_acc = (Dbconn.hml_acc == null ||
                     Dbconn.hml_acc.isEmpty())
                     ? "0" : Dbconn.hml_acc;
   String hml_pre = (Dbconn.hml_pre == null ||
                     Dbconn.hml_pre.isEmpty())
                     ? "0" : Dbconn.hml_pre;
   String hml_rec = (Dbconn.hml_recall == null ||
                     Dbconn.hml_recall.isEmpty())
                     ? "0" : Dbconn.hml_recall;
   String hml_f1  = (Dbconn.hml_f1_score == null ||
                     Dbconn.hml_f1_score.isEmpty())
                     ? "0" : Dbconn.hml_f1_score;
%>

   <script>
   $(function() {

      // ============================
      // Accuracy Chart
      // ============================
      $('#accuracyChart').highcharts({
         chart: { type: 'column' },
         title: { text: 'Accuracy Comparison' },
         xAxis: {
            categories: ['Random Forest','SVM','XGBoost'],
            title: { text: 'Methods' },
            labels: {
               rotation: -45,
               style: { fontSize:'13px' }
            }
         },
         yAxis: {
            min: 0,
            max: 100,
            title: { text: 'Accuracy (%)' }
         },
         legend: { enabled: false },
         tooltip: {
            pointFormat: '<b>{point.y:.2f}%</b>'
         },
         colors: ['#1565C0','#6A1B9A','#2E7D32'],
         series: [{
            name: 'Accuracy',
            data: [
               <%=rf_acc%>,
               <%=svm_acc%>,
               <%=hml_acc%>
            ],
            dataLabels: {
               enabled: true,
               format: '{point.y:.2f}%',
               style: { fontSize:'12px' }
            }
         }]
      });

      // ============================
      // Combined Metrics Chart
      // ============================
      $('#combinedChart').highcharts({
         chart: { type: 'column' },
         title: { text: 'Model Performance Comparison' },
         xAxis: {
            categories: ['Random Forest','SVM','XGBoost'],
            title: { text: 'Methods' },
            labels: {
               rotation: -45,
               style: { fontSize:'13px' }
            }
         },
         yAxis: {
            min: 0,
            max: 100,
            title: { text: 'Score (%)' }
         },
         tooltip: {
            pointFormat: '<b>{point.y:.2f}%</b>'
         },
         plotOptions: {
            column: { grouping: true }
         },
         series: [{
            name: 'Accuracy',
            color: '#1565C0',
            data: [
               <%=rf_acc%>,
               <%=svm_acc%>,
               <%=hml_acc%>
            ]
         },{
            name: 'Precision',
            color: '#6A1B9A',
            data: [
               <%=rf_pre%>,
               <%=svm_pre%>,
               <%=hml_pre%>
            ]
         },{
            name: 'Recall',
            color: '#2E7D32',
            data: [
               <%=rf_rec%>,
               <%=svm_rec%>,
               <%=hml_rec%>
            ]
         },{
            name: 'F1-Score',
            color: '#E65100',
            data: [
               <%=rf_f1%>,
               <%=svm_f1%>,
               <%=hml_f1%>
            ]
         }]
      });

   });
   </script>
</head>

<body class="clinic_version">

