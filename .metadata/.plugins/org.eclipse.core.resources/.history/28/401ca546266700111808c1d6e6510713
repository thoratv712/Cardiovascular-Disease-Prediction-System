<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>New Patient - CVD Risk Prediction</title>
    <link rel="stylesheet" href="css/bootstrap.min.css">
    <style>
        body { background-color: #f8f9fa; padding: 20px; }
        .card { margin-top: 20px; }
        .result { margin-top: 30px; }
    </style>
</head>
<body>
<div class="container">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3>New Patient Cardiovascular Disease Risk Prediction</h3>
        </div>
        <div class="card-body">
            
            <form action="PredictRiskServlet" method="post">
                <div class="row">
                    <div class="col-md-4 form-group">
                        <label>Age</label>
                        <input name="age" class="form-control" type="number" step="any" required>
                    </div>
                    <div class="col-md-4 form-group">
                        <label>Gender (0=Female, 1=Male)</label>
                        <input name="gender" class="form-control" type="number" min="0" max="1" required>
                    </div>
                    <div class="col-md-4 form-group">
                        <label>Chest Pain Type (0-3)</label>
                        <input name="chestpain" class="form-control" type="number" min="0" max="3" required>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        <label>Resting BP</label>
                        <input name="restingBP" class="form-control" type="number" required>
                    </div>
                    <div class="col-md-4 form-group">
                        <label>Serum Cholesterol</label>
                        <input name="serumcholestrol" class="form-control" type="number" required>
                    </div>
                    <div class="col-md-4 form-group">
                        <label>Fasting Blood Sugar (0/1)</label>
                        <input name="fastingbloodsugar" class="form-control" type="number" min="0" max="1" required>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        <label>Resting ECG (0-2)</label>
                        <input name="restingrelectro" class="form-control" type="number" min="0" max="2" required>
                    </div>
                    <div class="col-md-4 form-group">
                        <label>Max Heart Rate</label>
                        <input name="maxheartrate" class="form-control" type="number" required>
                    </div>
                    <div class="col-md-4 form-group">
                        <label>Exercise Angina (0/1)</label>
                        <input name="exerciseangia" class="form-control" type="number" min="0" max="1" required>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        <label>Oldpeak</label>
                        <input name="oldpeak" class="form-control" type="number" step="any" required>
                    </div>
                    <div class="col-md-4 form-group">
                        <label>Slope (0-2)</label>
                        <input name="slope" class="form-control" type="number" min="0" max="2" required>
                    </div>
                    <div class="col-md-4 form-group">
                        <label>No. of Major Vessels (0-3)</label>
                        <input name="noofmajorvessels" class="form-control" type="number" min="0" max="3" required>
                    </div>
                </div>

                <button type="submit" class="btn btn-success btn-lg mt-3">🚀 Predict Risk</button>
            </form>

            <!-- Result Section -->
            <% if (request.getAttribute("prediction") != null) { %>
            <div class="result card border-<%= request.getAttribute("prediction").toString().contains("High") ? "danger" : "success" %>">
                <div class="card-body">
                    <h4 class="text-<%= request.getAttribute("prediction").toString().contains("High") ? "danger" : "success" %>">
                        <%= request.getAttribute("prediction") %>
                    </h4>
                    <p><strong>Probability of Disease:</strong> <%= request.getAttribute("probability") %>%</p>
                    <p><strong>Model Used:</strong> <%= request.getAttribute("modelUsed") != null ? request.getAttribute("modelUsed") : "Random Forest" %></p>
                    
                    <% if (request.getAttribute("topFeatures") != null) { %>
                    <p><strong>Top Contributing Factors:</strong></p>
                    <ul>
                        <% for(String f : (java.util.List<String>)request.getAttribute("topFeatures")) { %>
                            <li><%= f %></li>
                        <% } %>
                    </ul>
                    <% } %>
                    
                    <a href="PredictRiskServlet" class="btn btn-primary">Predict Another Patient</a>
                </div>
            </div>
            <% } %>

        </div>
    </div>
</div>
</body>
</html>