package com.Classification;

import java.io.IOException;
import java.io.PrintWriter;
import java.util.Random;
import javax.servlet.RequestDispatcher;
import javax.servlet.ServletException;
import javax.servlet.annotation.WebServlet;
import javax.servlet.http.HttpServlet;
import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;

import weka.core.Instances;
import com.algo.ModelTrainer;
import com.connection.Dbconn;

/**
 * Servlet implementation class Classification_process
 */
@WebServlet("/Classification_process")
public class Classification_process extends HttpServlet {
    private static final long serialVersionUID = 1L;

    protected void doGet(HttpServletRequest request, HttpServletResponse response) 
            throws ServletException, IOException {
        doPost(request, response);
    }

    protected void doPost(HttpServletRequest request, HttpServletResponse response) 
            throws ServletException, IOException {

        PrintWriter pw = response.getWriter();
        try {
            // Load data with PSO selected features
            Instances data = Dbconn.loadARFF(Dbconn.PSO_Selected_Features_model);
            data.randomize(new Random(1));

            // 70/30 Train-Test Split
            int trainSize = (int) (data.numInstances() * 0.7);
            int testSize = data.numInstances() - trainSize;
            Instances train = new Instances(data, 0, trainSize);
            Instances test = new Instances(data, trainSize, testSize);

            // Train models and get best model
            ModelTrainer.TrainingResult result = ModelTrainer.train(train, test);

            // === IMPORTANT: Save Best Model for Prediction ===
            getServletContext().setAttribute("bestModel", result.getBestClassifier());
            getServletContext().setAttribute("bestModelName", result.getBestModelName());
            getServletContext().setAttribute("bestAccuracy", result.getBestAccuracy());

            pw.println("<script>alert('Classification Successfully! Best Model: " 
                       + result.getBestModelName() + " (" 
                       + String.format("%.2f", result.getBestAccuracy() * 100) 
                       + "%)');</script>");

        } catch (Exception e) {
            e.printStackTrace();
            pw.println("<script>alert('Error during Classification: " + e.getMessage() + "');</script>");
        }

        RequestDispatcher rd = request.getRequestDispatcher("/AnalysisPage.jsp");
        rd.include(request, response);
    }
}