   <div><br/><br/></div>
   <div><br/><br/></div>

   <div id="service" class="services wow fadeIn">
      <div class="container">

         <!-- Page Title -->
         <div class="row">
            <div class="col-md-12 text-center"
                 style="margin-bottom:25px;">
               <h2 style="color:#1565C0;">
                  📊 Model Performance Analysis
               </h2>
               <p style="color:#666;">
                  Comparison of Random Forest, SVM
                  and XGBoost classifiers
               </p>
            </div>
         </div>

         <!-- Metrics Summary Cards -->
         <div class="row" style="margin-bottom:25px;">
            <div class="col-md-12">
               <div class="model-section">
                  <h4>📈 Performance Metrics Summary</h4>
                  <div class="row">

                     <!-- RF -->
                     <div class="col-md-4">
                        <div style="background:#E3F2FD;
                                    border-radius:10px;
                                    padding:15px;
                                    margin-bottom:15px;">
                           <h5 style="color:#1565C0;
                                      margin-bottom:12px;">
                              🌲 Random Forest
                           </h5>
                           <table style="width:100%;
                                         font-size:13px;">
                              <tr>
                                 <td>Accuracy:</td>
                                 <td><strong>
                                    <%=Dbconn.rf_acc%>%
                                 </strong></td>
                              </tr>
                              <tr>
                                 <td>Precision:</td>
                                 <td><strong>
                                    <%=Dbconn.rf_pre%>%
                                 </strong></td>
                              </tr>
                              <tr>
                                 <td>Recall:</td>
                                 <td><strong>
                                    <%=Dbconn.rf_recall%>%
                                 </strong></td>
                              </tr>
                              <tr>
                                 <td>F1-Score:</td>
                                 <td><strong>
                                    <%=Dbconn.rf_f1_score%>%
                                 </strong></td>
                              </tr>
                           </table>
                        </div>
                     </div>

                     <!-- SVM -->
                     <div class="col-md-4">
                        <div style="background:#F3E5F5;
                                    border-radius:10px;
                                    padding:15px;
                                    margin-bottom:15px;">
                           <h5 style="color:#6A1B9A;
                                      margin-bottom:12px;">
                              ⚙ SVM
                           </h5>
                           <table style="width:100%;
                                         font-size:13px;">
                              <tr>
                                 <td>Accuracy:</td>
                                 <td><strong>
                                    <%=Dbconn.SVM_acc%>%
                                 </strong></td>
                              </tr>
                              <tr>
                                 <td>Precision:</td>
                                 <td><strong>
                                    <%=Dbconn.SVM_pre%>%
                                 </strong></td>
                              </tr>
                              <tr>
                                 <td>Recall:</td>
                                 <td><strong>
                                    <%=Dbconn.SVM_recall%>%
                                 </strong></td>
                              </tr>
                              <tr>
                                 <td>F1-Score:</td>
                                 <td><strong>
                                    <%=Dbconn.SVM_f1_score%>%
                                 </strong></td>
                              </tr>
                           </table>
                        </div>
                     </div>

                     <!-- XGBoost -->
                     <div class="col-md-4">
                        <div style="background:#E8F5E9;
                                    border-radius:10px;
                                    padding:15px;
                                    margin-bottom:15px;">
                           <h5 style="color:#2E7D32;
                                      margin-bottom:12px;">
                              🚀 XGBoost
                           </h5>
                           <table style="width:100%;
                                         font-size:13px;">
                              <tr>
                                 <td>Accuracy:</td>
                                 <td><strong>
                                    <%=Dbconn.hml_acc%>%
                                 </strong></td>
                              </tr>
                              <tr>
                                 <td>Precision:</td>
                                 <td><strong>
                                    <%=Dbconn.hml_pre%>%
                                 </strong></td>
                              </tr>
                              <tr>
                                 <td>Recall:</td>
                                 <td><strong>
                                    <%=Dbconn.hml_recall%>%
                                 </strong></td>
                              </tr>
                              <tr>
                                 <td>F1-Score:</td>
                                 <td><strong>
                                    <%=Dbconn.hml_f1_score%>%
                                 </strong></td>
                              </tr>
                           </table>
                        </div>
                     </div>

                  </div>
               </div>
            </div>
         </div>

         <!-- Accuracy Chart -->
         <div class="row">
            <div class="col-md-12">
               <div class="model-section">
                  <h4>📊 Accuracy Comparison</h4>
                  <div id="accuracyChart"
                       style="min-width:400px;
                              height:400px;">
                  </div>
               </div>
            </div>
         </div>

         <!-- Combined Chart -->
         <div class="row" style="margin-top:20px;">
            <div class="col-md-12">
               <div class="model-section">
                  <h4>📊 Combined Metrics Comparison</h4>
                  <div id="combinedChart"
                       style="min-width:400px;
                              height:400px;">
                  </div>
               </div>
            </div>
         </div>

         <!-- Performance Table -->
         <div class="row" style="margin-top:20px;">
            <div class="col-md-12">
               <div class="model-section">
                  <h4>📋 Detailed Performance Table</h4>
                  <table class="perf-table">
                     <tr>
                        <th>Model</th>
                        <th>Accuracy (%)</th>
                        <th>Precision (%)</th>
                        <th>Recall (%)</th>
                        <th>F1-Score (%)</th>
                        <th>Status</th>
                     </tr>
                     <tr>
                        <td><strong>🌲 Random Forest</strong></td>
                        <td><%=Dbconn.rf_acc%></td>
                        <td><%=Dbconn.rf_pre%></td>
                        <td><%=Dbconn.rf_recall%></td>
                        <td><%=Dbconn.rf_f1_score%></td>
                        <td>
                           <span class="best-badge">
                              ✓ Best Model
                           </span>
                        </td>
                     </tr>
                     <tr>
                        <td><strong>⚙ SVM</strong></td>
                        <td><%=Dbconn.SVM_acc%></td>
                        <td><%=Dbconn.SVM_pre%></td>
                        <td><%=Dbconn.SVM_recall%></td>
                        <td><%=Dbconn.SVM_f1_score%></td>
                        <td>Good</td>
                     </tr>
                     <tr>
                        <td><strong>🚀 XGBoost</strong></td>
                        <td><%=Dbconn.hml_acc%></td>
                        <td><%=Dbconn.hml_pre%></td>
                        <td><%=Dbconn.hml_recall%></td>
                        <td><%=Dbconn.hml_f1_score%></td>
                        <td>Good</td>
                     </tr>
                  </table>
               </div>
            </div>
         </div>

         <!-- Action Buttons -->
         <div class="row" style="margin-top:25px;">
            <div class="col-md-12 text-center">
               <a href="AnalysisExport" class="export-btn">
                  📥 Export Metrics CSV
               </a>
               <a href="PredictRisk" class="predict-btn-link">
                  🫀 Go to Prediction Module
               </a>
            </div>
         </div>

         <div><br/><br/></div>

      </div>
   </div>

