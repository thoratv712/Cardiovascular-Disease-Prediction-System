package com.admin;

import java.io.BufferedReader;
import java.io.IOException;
import java.io.InputStream;
import java.io.InputStreamReader;
import java.io.PrintWriter;
import java.sql.Connection;
import java.sql.Statement;
import javax.servlet.RequestDispatcher;
import javax.servlet.ServletException;
import javax.servlet.annotation.MultipartConfig;
import javax.servlet.annotation.WebServlet;
import javax.servlet.http.HttpServlet;
import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;
import javax.servlet.http.HttpSession;
import javax.servlet.http.Part;
import com.connection.Dbconn;

/**
 * Servlet implementation class Datasetupload
 */
//@WebServlet("/Datasetupload")
@MultipartConfig(
    fileSizeThreshold = 1024 * 1024 * 50,  // 50MB
    maxFileSize = 1024 * 1024 * 100,        // 100MB
    maxRequestSize = 1024 * 1024 * 1000     // 1000MB
)
public class Datasetupload extends HttpServlet {
    private static final long serialVersionUID = 1L;

    public Datasetupload() {
        super();
    }

    /**
     * doGet - Show upload page
     */
    protected void doGet(HttpServletRequest request, HttpServletResponse response)
            throws ServletException, IOException {

        // Check session
        HttpSession session = request.getSession(false);
        if (session == null || session.getAttribute("email") == null) {
            response.sendRedirect("loginpage");
            return;
        }

        RequestDispatcher rd = request.getRequestDispatcher("/PatientDataPage.jsp");
        rd.forward(request, response);
    }

    /**
     * doPost - Handle CSV file upload and insert into database
     */
    protected void doPost(HttpServletRequest request, HttpServletResponse response)
            throws ServletException, IOException {

        // Check session
        HttpSession session = request.getSession(false);
        if (session == null || session.getAttribute("email") == null) {
            response.sendRedirect("loginpage");
            return;
        }

        PrintWriter pw = response.getWriter();
        BufferedReader br = null;
        int i = 0;
        String line;

        try {
            // Get uploaded file
            Part filePart = request.getPart("txt_search");

            if (filePart == null || filePart.getSize() == 0) {
                pw.println("<script type='text/javascript'>");
                pw.println("alert('Please select a CSV file to upload!');");
                pw.println("window.location.href='Datasetupload';");
                pw.println("</script>");
                return;
            }

            InputStream inputStream = filePart.getInputStream();

            // Database connection
            Connection conn = Dbconn.conn();
            Statement sts = conn.createStatement();

            // Clear existing data
            sts.executeUpdate("TRUNCATE TABLE heart_data");

            br = new BufferedReader(new InputStreamReader(inputStream));

            int successCount = 0;

            while ((line = br.readLine()) != null) {
                String[] d = line.split(",");

                // Skip header row
                if (i == 0) {
                    i++;
                    continue;
                }

                // Validate column count
                if (d.length < 14) {
                    System.out.println("Skipping invalid row " + i + ": " + line);
                    i++;
                    continue;
                }

                try {
                    sts.executeUpdate(
                        "INSERT INTO heart_data(" +
                        "age, gender, chestpain, restingBP, " +
                        "serumcholestrol, fastingbloodsugar, restingrelectro, " +
                        "maxheartrate, exerciseangia, oldpeak, slope, " +
                        "noofmajorvessels, target) VALUES('" +
                        d[1].trim() + "','" +
                        d[2].trim() + "','" +
                        d[3].trim() + "','" +
                        d[4].trim() + "','" +
                        d[5].trim() + "','" +
                        d[6].trim() + "','" +
                        d[7].trim() + "','" +
                        d[8].trim() + "','" +
                        d[9].trim() + "','" +
                        d[10].trim() + "','" +
                        d[11].trim() + "','" +
                        d[12].trim() + "','" +
                        d[13].trim() + "')"
                    );
                    successCount++;
                    System.out.println("Inserted row " + i + ": " + line);

                } catch (Exception rowEx) {
                    System.out.println("Error inserting row " + i + ": " + rowEx.getMessage());
                }

                i++;
            }

            pw.println("<script type='text/javascript'>");
            pw.println("alert('Dataset uploaded successfully! " + successCount + " records inserted.');");
            pw.println("</script>");

        } catch (Exception e) {
            e.printStackTrace();
            pw.println("<script type='text/javascript'>");
            pw.println("alert('Error uploading dataset: " + e.getMessage() + "');");
            pw.println("</script>");

        } finally {
            if (br != null) {
                try {
                    br.close();
                } catch (IOException e) {
                    e.printStackTrace();
                }
            }
        }

        // Forward to home page
        RequestDispatcher rd = request.getRequestDispatcher("/PatientHomePage.jsp");
        rd.include(request, response);
    }
}